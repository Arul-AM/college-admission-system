# ─── Option A: Single connection string (Render, Railway, Supabase, Heroku) ───
DATABASE_URL=postgresql://admission_user:admission_pass_2024@localhost:5432/college_admission_db

# ─── Option B: Individual credentials (local / self-hosted) ──────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=college_admission_db
# DB_USER=admission_user
# DB_PASSWORD=admission_pass_2024

# ─── SSL ─────────────────────────────────────────────────────────────────────
# Leave unset (default): SSL on with rejectUnauthorized:false — works for most cloud DBs
# DB_SSL=false   → disable SSL (local dev / self-signed cert issues)
# DB_SSL=true    → force SSL (individual-creds mode)

# ─── Connection pool ─────────────────────────────────────────────────────────
DB_POOL_MAX=10

# ─── App ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=8h
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com
